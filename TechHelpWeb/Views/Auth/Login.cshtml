@model TechHelpWeb.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard" style="display: flex; justify-content: center; align-items: center; min-height: 75vh;">

    <div class="card" style="width: 100%; max-width: 450px;">

        @if (ViewBag.ErrorConexion != null)
        {
            <div class="message error" style="margin-bottom: 20px;">
                @ViewBag.ErrorConexion
            </div>
        }
        @if (ViewBag.SuccessConexion != null)
        {
            <div class="message exito" style="margin-bottom: 20px;">
                @ViewBag.SuccessConexion
            </div>
        }

        <h2 class="card-title" style="justify-content: center; border-left: none; margin-bottom: 2rem;">Inicio de Sesión</h2>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                @Html.LabelFor(m => m.Correo)
                @Html.TextBoxFor(m => m.Correo, new { placeholder = "ejemplo@techhelp.cl" })
                @Html.ValidationMessageFor(m => m.Correo, "", new { style = "color: var(--danger); font-size: 0.85rem; margin-top: 5px; display: block;" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Contrasena, "Contraseña")
                @Html.PasswordFor(m => m.Contrasena, new { placeholder = "••••••••" })
                @Html.ValidationMessageFor(m => m.Contrasena, "", new { style = "color: var(--danger); font-size: 0.85rem; margin-top: 5px; display: block;" })
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; margin-top: 1.5rem; padding: 1rem; font-size: 1.1rem;">
                Ingresar
            </button>

            @Html.ValidationSummary(true, "", new { style = "color: var(--danger); font-weight: bold; margin-top: 15px;" })
        }
    </div>
</div>